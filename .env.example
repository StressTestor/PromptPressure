# PromptPressure environment configuration
# Copy this to .env and fill in the keys you need

# Groq adapter — get a key at https://console.groq.com
GROQ_API_KEY=

# OpenRouter adapter — get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenAI adapter — get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Ollama adapter — local inference, no key needed
# Override the default http://localhost:11434 if running on a different host/port
# OLLAMA_BASE_URL=http://localhost:11434

# LM Studio adapter — local inference, no key needed
# Override the default http://127.0.0.1:1234 if running on a different port
# LM_STUDIO_BASE_URL=http://127.0.0.1:1234

# Database URL — defaults to local SQLite if not set
# DATABASE_URL=sqlite+aiosqlite:///data/promptpressure.db
