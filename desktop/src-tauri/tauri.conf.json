{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PromptPressure",
  "version": "2.6.0",
  "identifier": "com.stresstestor.promptpressure",
  "build": {
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "cd ../frontend && npm run build",
    "frontendDist": "../../frontend/out"
  },
  "app": {
    "windows": [
      {
        "title": "PromptPressure",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:9876 http://localhost:8000 http://localhost:11434; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "sidecar/*"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "wix": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}